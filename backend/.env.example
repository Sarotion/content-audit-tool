PORT=3001
FRONTEND_URL=http://localhost:5173

# Public URL of this backend (used to build PDF download links)
# Production example: https://backend-production-849c.up.railway.app
BACKEND_URL=http://localhost:3001

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# HubSpot Private App Token (Settings → Integrations → Private Apps)
HUBSPOT_TOKEN=pat-...

# Google PageSpeed API (optional, free at console.cloud.google.com)
PAGESPEED_API_KEY=

# Node environment
NODE_ENV=development
